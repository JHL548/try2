{
  "name": "@jhl548/duplicate-doc-core",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./src/style.css"
  },
  "files": [
    "dist",
    "src/style.css",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/check-encoding.mjs && npm run typecheck && npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^3.23.4",
    "@tiptap/pm": "^3.23.4"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.23.4"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
